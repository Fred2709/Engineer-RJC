#!/bin/bash

# ==========================
# Basic CentOS Security Script
# ==========================

echo "Starting system hardening..."

# 1. Update system
echo "Updating system..."
yum update -y

# 2. Install necessary tools
echo "Installing security tools..."
yum install -y epel-release
yum install -y fail2ban firewalld vim

# 3. Start and enable firewall
echo "Configuring firewall..."
systemctl start firewalld
systemctl enable firewalld

# Allow SSH (default port 22 for now)
firewall-cmd --permanent --add-service=ssh
firewall-cmd --reload

# 4. Create a new user
echo "Creating new user..."
read -p "Enter new username: " newuser
adduser $newuser
passwd $newuser

# Add to sudo group
usermod -aG wheel $newuser

# 5. Secure SSH
echo "Securing SSH..."

SSH_CONFIG="/etc/ssh/sshd_config"

# Backup config
cp $SSH_CONFIG ${SSH_CONFIG}.bak

# Change SSH port
sed -i 's/#Port 22/Port 2222/' $SSH_CONFIG

# Disable root login
sed -i 's/#PermitRootLogin yes/PermitRootLogin no/' $SSH_CONFIG

# Disable password authentication (optional - be careful!)
# sed -i 's/#PasswordAuthentication yes/PasswordAuthentication no/' $SSH_CONFIG

systemctl restart sshd

# Open new SSH port in firewall
firewall-cmd --permanent --add-port=2222/tcp
firewall-cmd --reload

# 6. Configure Fail2Ban
echo "Configuring Fail2Ban..."

systemctl start fail2ban
systemctl enable fail2ban

# Basic jail config
cat <<EOL > /etc/fail2ban/jail.local
[sshd]
enabled = true
port = 2222
logpath = /var/log/secure
maxretry = 5
EOL

systemctl restart fail2ban

# 7. Set file permissions
echo "Setting secure permissions..."
chmod 700 /root

# 8. Disable unused services (example)
echo "Disabling unnecessary services..."
systemctl disable avahi-daemon 2>/dev/null

echo "Security hardening complete!"
echo "IMPORTANT: Reconnect using SSH on port 2222"

